APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Reverb (set BROADCAST_CONNECTION=reverb when server runs: php artisan reverb:start)
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST="localhost"
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# FCM (legacy HTTP API; optional — push jobs no-op when empty)
# FCM_LEGACY_SERVER_KEY=
# FCM_HTTP_TIMEOUT=15

# APNs (iOS; HTTP/2 + JWT .p8 — optional; see .cursor/docs/messenger-push-apns.md)
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_AUTH_KEY_PATH=/absolute/path/to/AuthKey_XXXXX.p8
# APNS_BUNDLE_ID=ru.example.app
# APNS_USE_SANDBOX=false
# APNS_HTTP_TIMEOUT=15

# Agent tools in AI chats (OpenAI tool_calls; §11 roadmap)
# AI_AGENT_TOOLS_ENABLED=true
# AI_AGENT_MAX_TOOL_ROUNDS=6
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# VK Open API и OAuth (страница /admin/vktest — «Войти через OAuth»)
# VK_APP_ID=51417426
# VK_PROTECTED_KEY=
# VK_CLIENT_SECRET=   — Client Secret из настроек приложения VK (для OAuth)
# VK_REDIRECT_URL=https://m-engine.ru   — базовый URL для redirect_uri (на сервере за прокси задать явно)

# FTP deploy (for npm run deploy)
# FTP_HOST=ftp.example.com
# FTP_USER=username
# FTP_PASSWORD=password
# FTP_REMOTE_PATH=/public_html
# FTP_SECURE=false
#
# После выгрузки кода на сервер (vendor по FTP не заливается): обязательно
# composer install --no-dev --optimize-autoloader
# иначе не будет laravel/reverb и прочих пакетов из composer.json.
#
# Важно: команда `composer` в SSH часто запускается НЕ тем PHP, что обрабатывает сайт
# (старый системный php в PATH). Тогда все ошибки Composer будут про «нужна версия PHP …».
# Сделайте так:
# 1) В панели хостинга посмотрите версию PHP для домена (или временный phpinfo()).
# 2) Узнайте полный путь к этому же бинарнику для CLI (в cPanel: «Select PHP Version» /
#    «PHP CLI», у других — раздел документации «PHP для консоли»).
# 3) Вызывайте Composer через этот PHP явно, например:
#    /opt/alt/php84/usr/bin/php /usr/local/bin/composer install --no-dev --optimize-autoloader
#    или (если composer.phar в каталоге проекта):
#    /путь/к/php84 php composer.phar install --no-dev --optimize-autoloader
# Проверка: `/путь/к/php -v` должен совпадать по major.minor с тем, что в веб-интерфейсе.
#
# Если `/bin/composer` — это Composer 1 (из /usr/share/php): на PHP 8.4 сыплются Deprecated,
# Packagist с 2025-09 не обслуживает Composer 1. Не используйте системный composer — поставьте
# Composer 2 в каталог проекта и вызывайте только его:
#   cd /path/to/project
#   curl -sS https://getcomposer.org/installer -o composer-setup.php
#   /opt/alt/php84/usr/bin/php composer-setup.php --install-dir=. --filename=composer.phar
#   /opt/alt/php84/usr/bin/php -r "unlink('composer-setup.php');"
#   /opt/alt/php84/usr/bin/php composer.phar install --no-dev --optimize-autoloader
# Версию проверить: `/opt/alt/php84/usr/bin/php composer.phar --version` (должно быть 2.x).
# Обязательно: сначала cd в корень Laravel (где composer.json и composer.lock), иначе Composer
# пишет «No composer.lock» и ставит зависимости не в тот каталог. Установщик может положить
# composer.phar в родительскую папку — тогда mv composer.phar в корень проекта или указывайте
# полный путь к phar, оставаясь в каталоге сайта.
#
# Если при composer install падает с Class "Laravel\Reverb\ReverbServiceProvider" not found
# в ComposerScripts::prePackageUninstall — на диске ещё лежит старый bootstrap/cache/packages.php,
# а vendor в процессе пересборки. Сделайте:
#   cd /path/to/project
#   rm -f bootstrap/cache/packages.php bootstrap/cache/services.php bootstrap/cache/config.php
#   /opt/alt/php84/usr/bin/php composer.phar install --no-dev --optimize-autoloader --no-scripts
#   /opt/alt/php84/usr/bin/php composer.phar dump-autoload --optimize --no-dev
# (последняя команда снова запустит package:discover; если сомневаетесь — после install выполните
#   /opt/alt/php84/usr/bin/php artisan package:discover --ansi
# при уже полном vendor/).

